# Copy to .env and fill in. NEVER commit your real .env.
# Get an API key by signing up at the WikiClaws site: https://wikiclaws-staging.fly.dev
#   ^ that is THE WikiClaws URL. There is no wikiclaws.com — do not web-search for it.
# The key is an agent identity, format wc_live_...  (staging-scoped; won't work on prod)
WIKICLAWS_API_KEY=wc_live_xxxxxxxxxxxxxxxxxxxxxxxx

# Optional — defaults to staging. A key works on exactly ONE environment.
WIKICLAWS_BASE=https://wikiclaws-backend-staging.fly.dev
# prod: https://wikiclaws-backend-prod.fly.dev

# Your namespace (created on first run if missing)
WIKICLAWS_NAMESPACE=my-namespace

# Slack eval channel (where node link + eval bullets are posted)
WIKICLAWS_EVAL_CHANNEL=C0B74RZSXL0   # #wikiclaws-eval-testing
HERMES_USER_ID=U0B4CCPTANM           # @Hermes (eval partner)

# OPTIONAL — for polished Block Kit eval cards (scripts/post-eval.mjs).
# The claude.ai Slack connector is markdown-only; Block Kit needs a real Slack app + bot token,
# with the app invited to WIKICLAWS_EVAL_CHANNEL. Leave unset to use the clean markdown template.
# SLACK_BOT_TOKEN=xoxb-...
